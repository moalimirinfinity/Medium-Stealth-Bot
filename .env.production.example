# Medium Stealth Bot production template.
# Copy this file to `.env` and fill required secrets per deployment target.
# Do not commit live cookie/session secrets.

# ------------------------------------------------------------------------------
# Profile
# ------------------------------------------------------------------------------
APP_ENV="prod"

# ------------------------------------------------------------------------------
# Medium auth session
# ------------------------------------------------------------------------------
# Leave this empty when using line-by-line cookie fields below.
# If set, MEDIUM_SESSION takes precedence over MEDIUM_SESSION_* values.
MEDIUM_SESSION=""

# Required for authenticated API usage: SID, UID, XSRF.
# CF_CLEARANCE and CFUVID are optional session/challenge cookies.
# Paste cookie values line-by-line from a signed-in Medium session.
MEDIUM_SESSION_SID="..."
MEDIUM_SESSION_UID="..."
MEDIUM_SESSION_XSRF="..."
MEDIUM_SESSION_CF_CLEARANCE=""
MEDIUM_SESSION_CFUVID=""

# Optional explicit overrides for derived values.
# Leave blank to fall back to session-derived values.
MEDIUM_CSRF=""
MEDIUM_USER_REF=""

# ------------------------------------------------------------------------------
# Runtime and logging
# ------------------------------------------------------------------------------
# LOG_LEVEL typically one of: DEBUG, INFO, WARN, ERROR.
# LOG_FORMAT: pretty (developer-readable) or json (machine-readable).
CLIENT_MODE="stealth"
DAY_BOUNDARY_POLICY="utc"
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# ------------------------------------------------------------------------------
# Local paths and persistence
# ------------------------------------------------------------------------------
# Paths are relative to repository root unless absolute.
DATA_DIR=".data"
DB_PATH=".data/medium-stealth-bot.db"
RUN_ARTIFACTS_DIR=".data/runs"
PLAYWRIGHT_PROFILE_DIR=".data/playwright-profile"
# true = run headless browser; false = show visible browser window.
PLAYWRIGHT_HEADLESS="true"

# ------------------------------------------------------------------------------
# Medium API and operation contracts
# ------------------------------------------------------------------------------
GRAPHQL_ENDPOINT="https://medium.com/_/graphql"
IMPLEMENTATION_OPS_REGISTRY_PATH="captures/final/implementation_ops_2026-02-24.json"
CONTRACT_REGISTRY_STRICT="true"
CONTRACT_REGISTRY_VALIDATE_RESPONSE_FIELDS="true"
CONTRACT_REGISTRY_LIVE_NEWSLETTER_SLUG=""
CONTRACT_REGISTRY_LIVE_NEWSLETTER_USERNAME=""

# ------------------------------------------------------------------------------
# Operator throughput limits
# ------------------------------------------------------------------------------
# Integer limits per UTC day/per run.
MAX_ACTIONS_PER_DAY="400"
MAX_SUBSCRIBE_ACTIONS_PER_DAY="200"
MAX_UNFOLLOW_ACTIONS_PER_DAY="200"
MAX_CLAP_ACTIONS_PER_DAY="400"
LIVE_SESSION_DURATION_MINUTES="60"
LIVE_SESSION_TARGET_FOLLOW_ATTEMPTS="100"
LIVE_SESSION_MAX_PASSES="12"
MAX_FOLLOW_ACTIONS_PER_RUN="30"

# ------------------------------------------------------------------------------
# Discovery, reconcile, and cleanup
# ------------------------------------------------------------------------------
# FOLLOW_COOLDOWN_HOURS is in hours.
FOLLOW_CANDIDATE_LIMIT="30"
FOLLOW_COOLDOWN_HOURS="72"
UNFOLLOW_NONRECIPROCAL_AFTER_DAYS="7"
CLEANUP_UNFOLLOW_LIMIT="10"
CLEANUP_UNFOLLOW_WHITELIST_MIN_FOLLOWERS="2000"
RECONCILE_SCAN_LIMIT="200"
RECONCILE_PAGE_SIZE="50"

# ------------------------------------------------------------------------------
# Engagement and pacing behavior
# ------------------------------------------------------------------------------
# Wait, gap, and warmup settings are in seconds.
ENABLE_PRE_FOLLOW_CLAP="true"
MIN_READ_WAIT_SECONDS="30"
MAX_READ_WAIT_SECONDS="120"
MIN_ACTION_GAP_SECONDS="30"
MAX_ACTION_GAP_SECONDS="120"
MIN_SESSION_WARMUP_SECONDS="5"
MAX_SESSION_WARMUP_SECONDS="20"

# ------------------------------------------------------------------------------
# Safety guardrails
# ------------------------------------------------------------------------------
# hard: command exits non-zero on safety halt.
# soft: command exits zero and records halted status.
# Status code lists and detection tokens are comma-separated values.
# Detection tokens should be lowercase substring matches.
RISK_HALT_CONSECUTIVE_FAILURES="6"
RISK_HALT_MODE="hard"
ENABLE_CHALLENGE_HALT="true"
CHALLENGE_STATUS_CODES="403,429,503"
CHALLENGE_DETECTION_TOKENS="just a moment,attention required,cloudflare,cf-chl,captcha,turnstile,managed challenge"
ENABLE_SESSION_EXPIRY_HALT="true"
SESSION_EXPIRY_STATUS_CODES="401,419,440"
SESSION_EXPIRY_DETECTION_TOKENS="session expired,csrf,unauthorized,authentication required,login required,sign in"

# ------------------------------------------------------------------------------
# Retry policy
# ------------------------------------------------------------------------------
# Delay values are in seconds.
QUERY_MAX_RETRIES="1"
VERIFY_MAX_RETRIES="2"
MUTATION_MAX_RETRIES="2"
RETRY_BASE_DELAY_SECONDS="1.0"
RETRY_MAX_DELAY_SECONDS="8.0"
ADAPTIVE_RETRY_FAILURE_MULTIPLIER="0.5"

# ------------------------------------------------------------------------------
# Operator controls
# ------------------------------------------------------------------------------
OPERATOR_KILL_SWITCH="false"
PLAYWRIGHT_AUTH_BROWSER_CHANNEL="chrome"

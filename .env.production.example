APP_ENV="prod"

MEDIUM_SESSION="sid=...; uid=...; xsrf=...; cf_clearance=...; _cfuvid=..."
MEDIUM_CSRF="..."
MEDIUM_USER_REF="..." # Medium user_id only (not @username)

CLIENT_MODE="stealth"
DAY_BOUNDARY_POLICY="utc"
LOG_LEVEL="INFO"
LOG_FORMAT="json"

DATA_DIR=".data"
DB_PATH=".data/medium-stealth-bot.db"
RUN_ARTIFACTS_DIR=".data/runs"
PLAYWRIGHT_PROFILE_DIR=".data/playwright-profile"
PLAYWRIGHT_HEADLESS="true"

GRAPHQL_ENDPOINT="https://medium.com/_/graphql"
IMPLEMENTATION_OPS_REGISTRY_PATH="captures/final/implementation_ops_2026-02-24.json"
CONTRACT_REGISTRY_STRICT="true"
CONTRACT_REGISTRY_VALIDATE_RESPONSE_FIELDS="true"
CONTRACT_REGISTRY_LIVE_NEWSLETTER_SLUG=""
CONTRACT_REGISTRY_LIVE_NEWSLETTER_USERNAME=""

# Operator-defined safety profile: tune these limits for your own risk tolerance.
MAX_ACTIONS_PER_DAY="400"
MAX_SUBSCRIBE_ACTIONS_PER_DAY="200"
MAX_UNFOLLOW_ACTIONS_PER_DAY="200"
MAX_CLAP_ACTIONS_PER_DAY="400"
MAX_FOLLOW_ACTIONS_PER_RUN="30"

FOLLOW_CANDIDATE_LIMIT="30"
FOLLOW_COOLDOWN_HOURS="72"
UNFOLLOW_NONRECIPROCAL_AFTER_DAYS="7"
CLEANUP_UNFOLLOW_LIMIT="10"
RECONCILE_SCAN_LIMIT="200"
RECONCILE_PAGE_SIZE="50"

ENABLE_PRE_FOLLOW_CLAP="true"
MIN_READ_WAIT_SECONDS="30"
MAX_READ_WAIT_SECONDS="120"
MIN_ACTION_GAP_SECONDS="30"
MAX_ACTION_GAP_SECONDS="120"
MIN_SESSION_WARMUP_SECONDS="5"
MAX_SESSION_WARMUP_SECONDS="20"

# Safety switches are optional and fully controlled by this env profile.
RISK_HALT_CONSECUTIVE_FAILURES="6"
ENABLE_CHALLENGE_HALT="true"
CHALLENGE_STATUS_CODES="403,429,503"
CHALLENGE_DETECTION_TOKENS="just a moment,attention required,cloudflare,cf-chl,captcha,turnstile,managed challenge"
ENABLE_SESSION_EXPIRY_HALT="true"
SESSION_EXPIRY_STATUS_CODES="401,419,440"
SESSION_EXPIRY_DETECTION_TOKENS="session expired,csrf,unauthorized,authentication required,login required,sign in"

QUERY_MAX_RETRIES="1"
VERIFY_MAX_RETRIES="2"
MUTATION_MAX_RETRIES="2"
RETRY_BASE_DELAY_SECONDS="1.0"
RETRY_MAX_DELAY_SECONDS="8.0"
ADAPTIVE_RETRY_FAILURE_MULTIPLIER="0.5"

OPERATOR_KILL_SWITCH="false"
